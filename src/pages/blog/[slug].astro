---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Layout title={`${post.data.title} — Robertson Price`} description={post.data.title}>
<style>
  .post-page { padding-top: calc(80px + clamp(48px, 6vw, 80px)); padding-bottom: var(--section-gap); }
  .post-back { display: inline-flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 32px; transition: color 0.2s ease; }
  .post-back:hover { color: var(--color-text); }
  .post-back svg { width: 14px; height: 14px; }
  .post-date { font-size: 0.82rem; color: var(--color-text-tertiary); margin-bottom: 16px; }
  .post-header { max-width: 680px; margin-bottom: clamp(32px, 4vw, 48px); }
  .post-header h1 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.02em; }
  .post-divider { width: 40px; height: 1px; background: var(--color-border); margin: 28px 0; }
  .post-body { max-width: 680px; }
  .post-body :global(h2) { font-family: var(--font-serif); font-size: clamp(1.3rem, 2.5vw, 1.7rem); font-weight: 400; line-height: 1.3; letter-spacing: -0.02em; margin: 2.5em 0 0.8em; }
  .post-body :global(h3) { font-size: 1rem; font-weight: 600; margin: 2em 0 0.6em; letter-spacing: -0.01em; }
  .post-body :global(p) { font-size: 1rem; line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 1.4em; }
  .post-body :global(strong) { font-weight: 600; color: var(--color-text); }
  .post-body :global(em) { font-style: italic; }
  .post-body :global(a) { border-bottom: 1px solid var(--color-border); padding-bottom: 1px; transition: border-color 0.2s ease; }
  .post-body :global(a:hover) { border-color: var(--color-text); }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
  .post-body :global(li) { font-size: 1rem; line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 0.4em; }
  .post-body :global(blockquote) { border-left: 2px solid var(--color-border); padding-left: 20px; margin: 2em 0; }
  .post-body :global(blockquote p) { color: var(--color-text-secondary); font-style: italic; }
  .post-body :global(code) { font-size: 0.88em; background: var(--color-border-light); padding: 2px 6px; border-radius: 3px; }
  .post-body :global(pre) { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 8px; padding: 20px; overflow-x: auto; margin-bottom: 1.4em; }
  .post-body :global(pre code) { background: none; padding: 0; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--color-border-light); margin: 2.5em 0; }
  .post-footer { max-width: 680px; margin-top: 3em; padding-top: 2em; border-top: 1px solid var(--color-border-light); }
  .post-footer a { display: inline-flex; align-items: center; gap: 8px; font-size: 0.88rem; font-weight: 500; color: var(--color-text-secondary); transition: color 0.2s ease; }
  .post-footer a:hover { color: var(--color-text); }
  .post-footer svg { width: 14px; height: 14px; }
</style>
<div class="post-page">
  <div class="container">
    <a href="/blog" class="post-back">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
      All writing
    </a>
    <div class="post-header">
      <p class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1>{post.data.title}</h1>
    </div>
    <div class="post-divider"></div>
    <div class="post-body">
      <Content />
    </div>
    <div class="post-footer">
      <a href="/blog">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
        Back to all writing
      </a>
    </div>
  </div>
</div>
</Layout>

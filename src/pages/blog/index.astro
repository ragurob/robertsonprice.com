---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 12;
const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const currentPage = 1;
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const featuredPost = pagePosts[0];
const gridPosts = pagePosts.slice(1);

const categories = ['All', 'AI Tools & Products', 'AI Strategy', 'AI Infrastructure', 'Building & Shipping', 'Crypto & DeFi'];

function postSlug(post: any): string {
  return post.data.slug ?? post.id;
}

function excerpt(body: string, length = 160): string {
  const text = body
    .replace(/^#+\s+.*/gm, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`#>]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return text.length > length ? text.slice(0, length).replace(/\s+\S*$/, '') + '…' : text;
}

function readingTime(body: string): number {
  const words = body.replace(/[^a-zA-Z\s]/g, ' ').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---
<Layout title="Dispatches — Robertson Price" description="Notes on AI, building companies, and what happens at the frontier.">
<style>
  .blog-page {
    padding-top: calc(80px + var(--section-gap));
    padding-bottom: var(--section-gap);
  }
  .blog-header {
    max-width: 720px;
    margin-bottom: clamp(36px, 4vw, 56px);
  }
  .blog-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  .archive-intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 600px;
  }

  /* CATEGORY FILTERS */
  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: clamp(36px, 4vw, 56px);
    padding-bottom: clamp(24px, 3vw, 36px);
    border-bottom: 1px solid var(--color-border-light);
  }
  .filter-btn {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 7px 16px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .filter-btn:hover { color: var(--color-text); border-color: var(--color-text-tertiary); }
  .filter-btn.active { background: var(--color-text); color: var(--color-bg); border-color: var(--color-text); }

  /* NEWSLETTER BANNER */
  .newsletter-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: clamp(20px, 2.5vw, 28px) clamp(20px, 3vw, 36px);
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .newsletter-banner p {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .newsletter-banner strong { color: var(--color-text); font-weight: 500; }
  .newsletter-banner-form { display: flex; gap: 8px; flex-shrink: 0; }
  .newsletter-input-sm {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    padding: 9px 14px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    width: 200px;
    transition: border-color 0.2s ease;
  }
  .newsletter-input-sm:focus { border-color: var(--color-text); }
  .newsletter-btn-sm {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    padding: 9px 16px;
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }
  .newsletter-btn-sm:hover { background: var(--color-accent-hover); }

  /* ---- FEATURED POST ---- */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 48px);
    align-items: center;
    margin-bottom: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(48px, 6vw, 80px);
    border-bottom: 1px solid var(--color-border-light);
    text-decoration: none;
    color: inherit;
  }
  .featured-post:hover .featured-title { opacity: 0.7; }
  .featured-image {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-border-light);
  }
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .featured-post:hover .featured-image img { transform: scale(1.02); }
  .featured-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 16px;
  }
  .featured-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    transition: opacity 0.2s ease;
  }
  .featured-excerpt {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
  }
  .post-meta .sep { opacity: 0.4; }

  /* ---- POST GRID ---- */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(48px, 6vw, 80px);
  }
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .post-card:hover .card-title { opacity: 0.7; }
  .card-image {
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-border-light);
    margin-bottom: 20px;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .post-card:hover .card-image img { transform: scale(1.03); }
  .card-title {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    transition: opacity 0.2s ease;
  }
  .card-excerpt {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin-bottom: 16px;
    flex: 1;
  }
  .card-category {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: 8px;
  }

  /* ---- PAGINATION ---- */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding-top: clamp(32px, 4vw, 48px);
    border-top: 1px solid var(--color-border-light);
  }
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  .page-btn:hover { color: var(--color-text); border-color: var(--color-border); }
  .page-btn.active { color: var(--color-text); border-color: var(--color-border); background: var(--color-surface); }
  .page-btn.nav-btn { width: auto; padding: 0 16px; gap: 8px; font-size: 0.82rem; }
  .page-btn.nav-btn svg { width: 14px; height: 14px; }

  /* HIDDEN for category filter */
  .post-card.hidden { display: none; }
  .featured-post.hidden { display: none; }

  @media (max-width: 900px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
    .newsletter-banner { flex-direction: column; align-items: flex-start; }
    .newsletter-banner-form { width: 100%; }
    .newsletter-input-sm { flex: 1; width: auto; }
  }
  @media (max-width: 640px) {
    .featured-post { grid-template-columns: 1fr; }
    .post-grid { grid-template-columns: 1fr; }
    .newsletter-banner-form { flex-direction: column; }
    .newsletter-input-sm { width: 100%; }
  }
</style>
<div class="blog-page">
  <div class="container">
    <div class="blog-header">
      <h1>Dispatches</h1>
      <p class="archive-intro">From the Masterclass Archives — adapted from two invite-only groups where I've shared real-time analysis on AI, technology, and markets since 2021. Dates reflect when each piece was originally shared, not when it was published here.</p>
    </div>

    <div class="category-filters">
      {categories.map(cat => (
        <button class={`filter-btn${cat === 'All' ? ' active' : ''}`} data-category={cat}>{cat}</button>
      ))}
    </div>

    <div class="newsletter-banner">
      <p>📬 <strong>Join 500+ founders and operators</strong> getting my weekly take on AI — real analysis, not hype.</p>
      <form class="newsletter-banner-form" action="#" method="POST">
        <input class="newsletter-input-sm" type="email" name="email" placeholder="your@email.com" required />
        <button class="newsletter-btn-sm" type="submit">Subscribe →</button>
      </form>
    </div>

    {featuredPost && (
      <a href={`/blog/${postSlug(featuredPost)}`} class="featured-post" data-category={(featuredPost.data as any).category ?? 'All'}>
        <div class="featured-image">
          <img src={`/images/blog/${featuredPost.id}.png`} alt={featuredPost.data.title} loading="eager" />
        </div>
        <div class="featured-content">
          <p class="featured-label">Latest</p>
          {(featuredPost.data as any).category && <p class="card-category">{(featuredPost.data as any).category}</p>}
          <h2 class="featured-title">{featuredPost.data.title}</h2>
          <p class="featured-excerpt">{excerpt(featuredPost.body || '', 200)}</p>
          <div class="post-meta">
            <span>{formatDate(featuredPost.data.date)}</span>
            <span class="sep">·</span>
            <span>{readingTime(featuredPost.body || '')} min read</span>
          </div>
        </div>
      </a>
    )}

    <div class="post-grid" id="post-grid">
      {gridPosts.map(post => (
        <a href={`/blog/${postSlug(post)}`} class="post-card" data-category={(post.data as any).category ?? ''}>
          <div class="card-image">
            <img src={`/images/blog/${post.id}.png`} alt={post.data.title} loading="lazy" />
          </div>
          {(post.data as any).category && <p class="card-category">{(post.data as any).category}</p>}
          <h2 class="card-title">{post.data.title}</h2>
          <p class="card-excerpt">{excerpt(post.body || '')}</p>
          <div class="post-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="sep">·</span>
            <span>{readingTime(post.body || '')} min read</span>
          </div>
        </a>
      ))}
    </div>

    <nav class="pagination" aria-label="Pagination" id="pagination">
      <span class="page-btn active">1</span>
      {Array.from({ length: Math.min(totalPages - 1, 6) }, (_, i) => i + 2).map(p => (
        <a href={`/blog/page/${p}`} class="page-btn">{p}</a>
      ))}
      {totalPages > 7 && <span class="page-btn" style="border:none">…</span>}
      {totalPages > 7 && <a href={`/blog/page/${totalPages}`} class="page-btn">{totalPages}</a>}
      <a href="/blog/page/2" class="page-btn nav-btn">
        Next
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </nav>
  </div>
</div>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const postCards = document.querySelectorAll('.post-card');
  const featuredPost = document.querySelector('.featured-post') as HTMLElement | null;
  const pagination = document.getElementById('pagination');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const category = (btn as HTMLElement).dataset.category || 'All';

      postCards.forEach(card => {
        const cardEl = card as HTMLElement;
        const cardCat = cardEl.dataset.category || '';
        if (category === 'All' || cardCat === category) {
          cardEl.classList.remove('hidden');
        } else {
          cardEl.classList.add('hidden');
        }
      });

      // Handle featured post
      if (featuredPost) {
        const featCat = featuredPost.dataset.category || '';
        if (category === 'All' || featCat === category) {
          featuredPost.classList.remove('hidden');
        } else {
          featuredPost.classList.add('hidden');
        }
      }

      // Hide pagination when filtering
      if (pagination) {
        pagination.style.display = category === 'All' ? '' : 'none';
      }
    });
  });
</script>
</Layout>

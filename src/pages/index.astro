---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Layout title="Robertson Price — CEO, Builder, AI Strategist" ogImage="/robertson.jpg">
<style>
  /* HERO */
  .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 80px; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(40px, 6vw, 80px); align-items: center; }
  .hero-content { max-width: 580px; }
  .hero-label { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-tertiary); margin-bottom: 24px; }
  .hero-headline { font-family: var(--font-serif); font-size: clamp(2.4rem, 4vw, 3.2rem); font-weight: 400; line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 28px; }
  .hero-headline .highlight { background: var(--color-text); color: var(--color-bg); padding: 4px 12px; display: inline-block; line-height: 1.2; }
  .hero-headline .tagline { display: block; font-size: 0.65em; font-weight: 400; margin-top: 12px; opacity: 0.7; }
  .hero-bio { font-size: 1.05rem; line-height: 1.75; color: var(--color-text-secondary); margin-bottom: 36px; }
  .hero-cta { display: inline-flex; align-items: center; gap: 10px; font-size: 0.9rem; font-weight: 500; padding: 14px 28px; background: var(--color-accent); color: var(--color-bg); border-radius: 6px; transition: all 0.25s ease; }
  .hero-cta:hover { background: var(--color-accent-hover); transform: translateY(-1px); }
  .hero-cta svg { width: 16px; height: 16px; transition: transform 0.25s ease; }
  .hero-cta:hover svg { transform: translateX(3px); }
  .hero-image { position: relative; }
  .hero-image-wrapper { aspect-ratio: 4/5; background: var(--color-border-light); border-radius: 12px; overflow: hidden; }
  .hero-image-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  .hero-sketch { position: absolute; top: 20px; right: 20px; width: 120px; height: 120px; opacity: 0.25; pointer-events: none; }

  /* SOCIAL PROOF */
  .social-proof { background: var(--color-text); color: var(--color-bg); padding: clamp(48px, 6vw, 72px) 0; }
  .social-proof-header { text-align: center; margin-bottom: clamp(36px, 4vw, 48px); }
  .social-proof-label { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(250,250,249,0.5); margin-bottom: 10px; }
  .social-proof-title { font-family: var(--font-serif); font-size: clamp(1.2rem, 2vw, 1.5rem); font-weight: 400; letter-spacing: -0.02em; opacity: 0.9; }
  .proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(250,250,249,0.1); border: 1px solid rgba(250,250,249,0.1); border-radius: 8px; overflow: hidden; margin-bottom: 32px; }
  .proof-card { background: var(--color-text); padding: clamp(20px, 2.5vw, 32px); }
  .proof-company { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(250,250,249,0.45); margin-bottom: 10px; }
  .proof-metric { font-family: var(--font-serif); font-size: clamp(1.1rem, 1.8vw, 1.35rem); font-weight: 400; line-height: 1.3; letter-spacing: -0.01em; color: var(--color-bg); margin-bottom: 8px; }
  .proof-detail { font-size: 0.82rem; line-height: 1.5; color: rgba(250,250,249,0.55); }
  .proof-seen { text-align: center; font-size: 0.82rem; color: rgba(250,250,249,0.45); letter-spacing: 0.02em; }
  .proof-seen strong { color: rgba(250,250,249,0.75); font-weight: 500; }

  /* NEWSLETTER (homepage) */
  .newsletter-hp { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: clamp(32px, 4vw, 48px); max-width: 560px; }
  .newsletter-hp h3 { font-family: var(--font-serif); font-size: clamp(1.2rem, 2vw, 1.5rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 8px; }
  .newsletter-hp p { font-size: 0.9rem; line-height: 1.65; color: var(--color-text-secondary); margin-bottom: 20px; }
  .newsletter-form { display: flex; gap: 10px; }
  .newsletter-input { flex: 1; font-family: var(--font-sans); font-size: 0.9rem; padding: 11px 16px; border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-bg); color: var(--color-text); outline: none; transition: border-color 0.2s ease; }
  .newsletter-input:focus { border-color: var(--color-text); }
  .newsletter-btn { font-family: var(--font-sans); font-size: 0.88rem; font-weight: 500; padding: 11px 20px; background: var(--color-accent); color: var(--color-bg); border: none; border-radius: 6px; cursor: pointer; white-space: nowrap; transition: background 0.2s ease; }
  .newsletter-btn:hover { background: var(--color-accent-hover); }

  /* TRAJECTORY */
  .trajectory { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .trajectory-header { max-width: 640px; margin-bottom: clamp(48px, 6vw, 72px); }
  .trajectory-header h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 16px; }
  .trajectory-header p { font-size: 0.95rem; line-height: 1.7; color: var(--color-text-secondary); }
  .timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
  .timeline::before { content: ''; position: absolute; left: 106px; top: 0; bottom: 0; width: 1px; background: var(--color-border); }
  .timeline-item { display: grid; grid-template-columns: 90px 1fr; gap: 40px; padding: 28px 0; position: relative; }
  .timeline-item::after { content: ''; position: absolute; left: 102px; top: 34px; width: 9px; height: 9px; border-radius: 50%; background: var(--color-border); border: 2px solid var(--color-surface); transition: background 0.3s ease; }
  .timeline-item:hover::after { background: var(--color-text); }
  .timeline-year { font-size: 0.85rem; font-weight: 500; color: var(--color-text-tertiary); font-variant-numeric: tabular-nums; text-align: right; padding-top: 2px; }
  .timeline-content h3 { font-size: 1rem; font-weight: 600; margin-bottom: 6px; letter-spacing: -0.01em; }
  .timeline-content p { font-size: 0.92rem; line-height: 1.7; color: var(--color-text-secondary); }
  .timeline-accent { font-weight: 500; color: var(--color-text); }
  .timeline-sketch { float: right; width: 96px; height: 96px; margin: -4px 0 12px 20px; opacity: 0.65; transition: opacity 0.4s ease; }
  .timeline-item:hover .timeline-sketch { opacity: 0.85; }
  .timeline-sketch svg { width: 100%; height: 100%; }
  .patent-sketch { display: flex; justify-content: center; margin-bottom: clamp(40px, 5vw, 60px); opacity: 0.55; }
  .patent-sketch svg { width: clamp(280px, 40vw, 400px); height: auto; }
  .section-ornament { display: flex; justify-content: center; padding: 32px 0; opacity: 0.5; }
  .section-ornament svg { width: 180px; height: auto; }

  /* ADVISORY */
  .advisory-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(40px, 6vw, 80px); }
  .advisory-left h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 20px; }
  .advisory-left p { font-size: 0.95rem; line-height: 1.7; color: var(--color-text-secondary); }
  .advisory-right { display: flex; flex-direction: column; gap: 32px; }
  .advisory-item { padding-bottom: 32px; border-bottom: 1px solid var(--color-border-light); }
  .advisory-item:last-child { border-bottom: none; padding-bottom: 0; }
  .advisory-item h3 { font-size: 1rem; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.01em; }
  .advisory-item p { font-size: 0.92rem; line-height: 1.65; color: var(--color-text-secondary); }
  .advisory-item-icon { width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.6; }

  /* VENTURES */
  .ventures-header { margin-bottom: clamp(40px, 5vw, 64px); }
  .ventures-header h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 12px; }
  .ventures-header p { font-size: 0.95rem; color: var(--color-text-secondary); max-width: 520px; }
  .ventures-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .venture-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: clamp(24px, 2.5vw, 32px); transition: all 0.3s ease; display: flex; flex-direction: column; }
  .venture-card:hover { border-color: var(--color-text-tertiary); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.04); }
  .venture-label { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-tertiary); margin-bottom: 12px; }
  .venture-card h3 { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 500; margin-bottom: 10px; letter-spacing: -0.01em; }
  .venture-card p { font-size: 0.88rem; line-height: 1.6; color: var(--color-text-secondary); flex: 1; }
  .venture-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 20px; font-size: 0.82rem; font-weight: 500; color: var(--color-text); opacity: 0; transform: translateX(-4px); transition: all 0.25s ease; }
  .venture-card:hover .venture-link { opacity: 1; transform: translateX(0); }
  .venture-link svg { width: 14px; height: 14px; }
  .ventures-sketch { display: flex; justify-content: flex-end; margin-bottom: 24px; opacity: 0.4; }
  .ventures-sketch svg { width: 100px; height: 100px; }

  /* WRITING */
  .writing { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .writing-header { margin-bottom: clamp(40px, 5vw, 56px); }
  .writing-header h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 12px; }
  .writing-header p { font-size: 0.95rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 560px; }
  .writing-sketch { float: left; width: 80px; height: 80px; margin: 0 24px 16px 0; opacity: 0.45; }
  .writing-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 32px; }
  .writing-item { display: grid; grid-template-columns: 80px 1fr auto; gap: 20px; align-items: center; padding: 20px 0; border-bottom: 1px solid var(--color-border-light); transition: background 0.2s ease; }
  .writing-item:first-child { border-top: 1px solid var(--color-border-light); }
  .writing-item:hover { color: var(--color-text); }
  .writing-date { font-size: 0.82rem; color: var(--color-text-tertiary); font-variant-numeric: tabular-nums; }
  .writing-title { font-size: 0.95rem; font-weight: 500; letter-spacing: -0.01em; }
  .writing-tag { font-size: 0.75rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-text-tertiary); background: var(--color-border-light); padding: 4px 10px; border-radius: 20px; }
  .writing-more { display: inline-flex; align-items: center; gap: 8px; font-size: 0.88rem; font-weight: 500; color: var(--color-text-secondary); transition: color 0.2s ease; }
  .writing-more:hover { color: var(--color-text); }

  /* MEDIA */
  .media { padding: var(--section-gap) 0; }
  .media-header { margin-bottom: clamp(32px, 4vw, 48px); }
  .media-header h2 { font-family: var(--font-serif); font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 400; letter-spacing: -0.02em; margin-bottom: 12px; }
  .media-header p { font-size: 0.95rem; color: var(--color-text-secondary); max-width: 520px; }
  .media-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .media-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: clamp(24px, 2.5vw, 32px); transition: all 0.3s ease; display: flex; flex-direction: column; gap: 12px; }
  .media-card:hover { border-color: var(--color-text-tertiary); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.04); }
  .media-outlet { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-tertiary); }
  .media-card h3 { font-size: 1rem; font-weight: 600; line-height: 1.4; letter-spacing: -0.01em; }
  .media-date { font-size: 0.82rem; color: var(--color-text-tertiary); }
  .media-link { display: inline-flex; align-items: center; gap: 6px; margin-top: auto; font-size: 0.82rem; font-weight: 500; color: var(--color-text); opacity: 0.6; transition: opacity 0.2s ease; }
  .media-card:hover .media-link { opacity: 1; }
  .media-link svg { width: 12px; height: 12px; }

  /* CONTACT */
  .contact h2 { font-family: var(--font-serif); font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 400; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 16px; }
  .contact p { font-size: 0.95rem; line-height: 1.7; color: var(--color-text-secondary); max-width: 480px; margin-bottom: 36px; }
  .contact-links { display: flex; gap: 16px; }
  .contact-link { display: inline-flex; align-items: center; gap: 8px; font-size: 0.88rem; font-weight: 500; padding: 12px 24px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 6px; transition: all 0.2s ease; }
  .contact-link:hover { border-color: var(--color-text); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-image { display: none; }
    .advisory-grid { grid-template-columns: 1fr; }
    .ventures-grid { grid-template-columns: repeat(2, 1fr); }
    .media-grid { grid-template-columns: 1fr; }
    .proof-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .proof-grid { grid-template-columns: 1fr; }
    .newsletter-form { flex-direction: column; }
    .timeline::before { display: none; }
    .timeline-item { grid-template-columns: 1fr; gap: 4px; }
    .timeline-item::after { display: none; }
    .timeline-year { text-align: left; }
    .ventures-grid { grid-template-columns: 1fr; }
    .writing-item { grid-template-columns: 1fr; gap: 4px; }
    .writing-tag { display: none; }
    .contact-links { flex-direction: column; }
  }
</style>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="container">
    <div class="hero-sketch">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 50 Q25 30 40 50 T70 50 T100 50" stroke="var(--color-sketch)" stroke-width="1.2" fill="none"/>
        <path d="M10 65 Q25 45 40 65 T70 65 T100 65" stroke="var(--color-sketch)" stroke-width="1" fill="none" opacity="0.6"/>
        <path d="M10 35 Q25 15 40 35 T70 35 T100 35" stroke="var(--color-sketch)" stroke-width="1" fill="none" opacity="0.6"/>
        <circle cx="40" cy="50" r="2.5" fill="var(--color-sketch)" opacity="0.5"/>
        <circle cx="70" cy="50" r="2.5" fill="var(--color-sketch)" opacity="0.5"/>
      </svg>
    </div>
    <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-label fade-in">Founder &amp; CEO</p>
        <h1 class="hero-headline fade-in stagger-1"><span class="tagline highlight">I've built through them all.</span> Search, Video, Content, Commerce, AI.</h1>
        <p class="hero-bio fade-in stagger-2">I've spent 25 years building companies at the frontier of internet technology — from early search and streaming video to content networks and e-commerce. I've been part of teams that shaped how people use the web. Today I run <a href="https://ragu.ai" class="subtle-link">Ragu.AI</a> and build AI-native products across <a href="https://tezit.com" class="subtle-link">communication</a>, <a href="https://nourova.com" class="subtle-link">biometrics</a>, and <a href="https://mypa.chat" class="subtle-link">personal AI</a>.</p>
        <a href="#ventures" class="hero-cta fade-in stagger-3">
          See what I'm building
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
      <div class="hero-image fade-in stagger-2">
        <div class="hero-image-wrapper">
          <img src="/robertson.jpg" alt="Robertson Price" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL PROOF -->
<section class="social-proof">
  <div class="container">
    <div class="social-proof-header">
      <p class="social-proof-label">Track Record</p>
      <p class="social-proof-title">25+ Years Building Internet Companies</p>
    </div>
    <div class="proof-grid">
      <div class="proof-card">
        <p class="proof-company">iWon.com</p>
        <p class="proof-metric">$750M Acquisition</p>
        <p class="proof-detail">Part of the team that drove 20% of Google's early search revenue</p>
      </div>
      <div class="proof-card">
        <p class="proof-company">MyVideoDaily</p>
        <p class="proof-metric">3M Views / Month</p>
        <p class="proof-detail">Founded &amp; scaled — larger than Fox News + NBC streaming combined</p>
      </div>
      <div class="proof-card">
        <p class="proof-company">Answers Network</p>
        <p class="proof-metric">32M Monthly Visitors</p>
        <p class="proof-detail">600 websites, 45 employees, 100% founder-owned</p>
      </div>
      <div class="proof-card">
        <p class="proof-company">Rebates.com</p>
        <p class="proof-metric">$500K / Month</p>
        <p class="proof-detail">Founded, scaled paid marketing operation → acquired</p>
      </div>
      <div class="proof-card">
        <p class="proof-company">Ragu.AI</p>
        <p class="proof-metric">$55K+ MRR</p>
        <p class="proof-detail">Enterprise AI infrastructure for luxury &amp; premium brands</p>
      </div>
      <div class="proof-card" style="display:flex;flex-direction:column;justify-content:center;">
        <p class="proof-company">Media</p>
        <p class="proof-metric">As Seen On</p>
        <p class="proof-detail">ABC 6abc News — AI commentary &amp; technology analysis</p>
      </div>
    </div>
    <p class="proof-seen">Building at the internet frontier since <strong>1996</strong></p>
  </div>
</section>

<!-- TRAJECTORY -->
<section class="trajectory" id="trajectory">
  <div class="container">
    <div class="trajectory-header">
      <h2 class="fade-in">25 years of building<br>at the frontier.</h2>
      <p class="fade-in stagger-1">Every few years, a technology shift changes how businesses operate. I've been early to each one — not as an observer, but as a builder. I hold a granted U.S. patent (<a href="https://patents.google.com/patent/US10021455B2/" class="subtle-link" target="_blank">10,021,455</a>) for a system that uses luminaire-based optical communication to identify content and determine viewership — an early step in the thinking that led to <a href="https://nourova.com" class="subtle-link" target="_blank">Nourova</a>, for which I have a patent pending (<a href="https://patents.google.com/patent/US20240414397A1/" class="subtle-link" target="_blank">US 18/330,111</a>) — a real-time AI system that reads biometrics and continuously adapts content based on physiological response.</p>
    </div>

    <div class="patent-sketch fade-in">
      <svg viewBox="0 0 320 180" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M160 12 Q154 12 152 18 L148 28 Q146 32 150 34 L170 34 Q174 32 172 28 L168 18 Q166 12 160 12Z" stroke="var(--color-sketch)" stroke-width="1.2" stroke-linecap="round"/>
        <line x1="156" y1="34" x2="164" y2="34" stroke="var(--color-sketch)" stroke-width="1.2"/>
        <line x1="160" y1="8" x2="160" y2="4" stroke="var(--color-sketch)" stroke-width="1"/>
        <path d="M152 36 L88 72" stroke="var(--color-sketch)" stroke-width="0.8" stroke-dasharray="3 4" opacity="0.6"/>
        <path d="M168 36 L232 72" stroke="var(--color-sketch)" stroke-width="0.8" stroke-dasharray="3 4" opacity="0.6"/>
        <path d="M155 36 L120 100" stroke="var(--color-sketch)" stroke-width="0.8" stroke-dasharray="3 4" opacity="0.5"/>
        <path d="M165 36 L240 100" stroke="var(--color-sketch)" stroke-width="0.8" stroke-dasharray="3 4" opacity="0.5"/>
        <ellipse cx="88" cy="80" rx="14" ry="18" stroke="var(--color-sketch)" stroke-width="1.2"/>
        <circle cx="88" cy="70" r="6" stroke="var(--color-sketch)" stroke-width="1"/>
        <path d="M80 100 L80 130 M96 100 L96 130 M76 130 L100 130" stroke="var(--color-sketch)" stroke-width="1" stroke-linecap="round"/>
        <rect x="210" y="76" width="72" height="48" rx="3" stroke="var(--color-sketch)" stroke-width="1.2"/>
        <rect x="214" y="80" width="64" height="40" rx="1" stroke="var(--color-sketch)" stroke-width="0.6" opacity="0.4"/>
        <path d="M236 124 L234 140 L258 140 L256 124" stroke="var(--color-sketch)" stroke-width="1" stroke-linecap="round"/>
        <line x1="228" y1="140" x2="264" y2="140" stroke="var(--color-sketch)" stroke-width="1.2"/>
        <text x="160" y="50" text-anchor="middle" font-family="var(--font-sans)" font-size="7" fill="var(--color-sketch)" opacity="0.7">110</text>
        <text x="92" y="158" text-anchor="middle" font-family="var(--font-sans)" font-size="7" fill="var(--color-sketch)" opacity="0.7">130</text>
        <text x="246" y="158" text-anchor="middle" font-family="var(--font-sans)" font-size="7" fill="var(--color-sketch)" opacity="0.7">120</text>
      </svg>
    </div>

    <div class="timeline">
      <div class="timeline-item fade-in">
        <span class="timeline-year">1996</span>
        <div class="timeline-content">
          <div class="timeline-sketch">
            <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 50 V22 Q14 10 28 6 Q42 10 42 22 V50" stroke="var(--color-sketch)" stroke-width="1.2" stroke-linecap="round"/>
              <line x1="10" y1="50" x2="46" y2="50" stroke="var(--color-sketch)" stroke-width="1.2"/>
